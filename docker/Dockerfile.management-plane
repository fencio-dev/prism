FROM node:20-slim AS ui-builder
WORKDIR /app/ui
COPY ui/package*.json ./
RUN npm ci
COPY ui/ ./
RUN npm run build

FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    git curl \
    && rm -rf /var/lib/apt/lists/* && \
    pip install --no-cache-dir uv

COPY management_plane/ /app/management_plane/
COPY data_plane/proto/ /app/data_plane/proto/

RUN cd /app/management_plane && \
    uv sync --no-dev

RUN mkdir -p /app/management_plane/app/generated && \
    cd /app/management_plane && \
    uv run python -m grpc_tools.protoc \
        -I /app/data_plane/proto \
        --python_out=app/generated \
        --grpc_python_out=app/generated \
        /app/data_plane/proto/rule_installation.proto && \
    sed -i 's/^import rule_installation_pb2/from . import rule_installation_pb2/' app/generated/rule_installation_pb2_grpc.py && \
    printf '# Generated gRPC code from protobuf definitions\nfrom .rule_installation_pb2 import *\nfrom .rule_installation_pb2_grpc import *\n' > app/generated/__init__.py

RUN mkdir -p /app/data/logs /app/data/chroma_data

VOLUME ["/app/data"]

EXPOSE 47000

ENV PRISM_PORT=47000 \
    DATA_PLANE_URL=data-plane:50051

COPY --from=ui-builder /app/ui/dist /app/ui/dist

ARG TARGETARCH
ARG PRISM_VERSION
RUN curl -fsSL "https://github.com/fencio-dev/prism/releases/download/${PRISM_VERSION}/prism-linux-${TARGETARCH}" \
    -o /usr/local/bin/prism && \
    chmod +x /usr/local/bin/prism

WORKDIR /app/management_plane

CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "47000"]
